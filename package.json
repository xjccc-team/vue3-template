{
  "name": "vue3-template",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --open",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.json --composite false",
    "lint": "eslint .",
    "prepare": "husky && pnpm echo:husky",
    "echo:husky": "echo 'npx --no-install nano-staged' > .husky/pre-commit && echo 'npx --no-install commitlint --edit \"$1\"' > .husky/commit-msg",
    "commit": "git-cz"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "pinia": "^3.0.4",
    "qs": "^6.15.0",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.15.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "nano-staged": "^0.9.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  },
  "husky": {
    "hooks": {
      "pre-commit": "nano-staged"
    }
  },
  "nano-staged": {
    "*.{ts,vue}": "eslint . --fix"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
